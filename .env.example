# Hetzner Cloud API token (Project -> Security -> API Tokens, needs Read & Write
# since the bot creates/deletes images and enables Backup)
HETZNER_API_TOKEN=

# Discord webhook URL for notifications. Optional - leave empty to only log
# to stdout/console (e.g. `docker logs`) without sending anything to Discord.
DISCORD_WEBHOOK_URL=

# Cron expression for how often the bot checks servers (this is just the check
# frequency, not the per-server snapshot interval - see snapshot-bot.interval-days
# label below). Default: once a day at 03:00.
CRON_SCHEDULE=0 3 * * *

# Timezone CRON_SCHEDULE is interpreted in (passed explicitly to node-cron,
# not read from the container's system time). Only needs to be set once here.
CRON_TIMEZONE=Europe/Helsinki

# Directory where state (snapshot history) is persisted
DATA_DIR=/data

# Default rotation and interval for servers that don't have their own
# snapshot-bot.rotation / snapshot-bot.interval-days labels in Hetzner
DEFAULT_ROTATION=7
DEFAULT_INTERVAL_DAYS=1
